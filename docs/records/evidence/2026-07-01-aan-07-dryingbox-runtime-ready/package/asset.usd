                        token info:mdl:sourceAsset:subIdentifier = "Aluminum_Anodized_Charcoal"
                    }
                }
                def Material "task_button_mat"
                {
                    token outputs:surface.connect = </World/labutopia_level1_poc/obj_obj_DryingBox_01/Looks/task_button_mat/PreviewSurface.outputs:surface>
                    token outputs:mdl:surface.connect = </World/labutopia_level1_poc/obj_obj_DryingBox_01/Looks/task_button_mat/OmniPBR.outputs:out>
                    token outputs:mdl:displacement.connect = </World/labutopia_level1_poc/obj_obj_DryingBox_01/Looks/task_button_mat/OmniPBR.outputs:out>
                    token outputs:mdl:volume.connect = </World/labutopia_level1_poc/obj_obj_DryingBox_01/Looks/task_button_mat/OmniPBR.outputs:out>
                    def Shader "PreviewSurface"
                    {
                        uniform token info:id = "UsdPreviewSurface"
                        color3f inputs:diffuseColor = (1, 0.48, 0.04)
                        float inputs:metallic = 0
                        float inputs:roughness = 0.85
                        token outputs:surface
                    }
                    def Shader "OmniPBR"
                    {
                        uniform token info:implementationSource = "sourceAsset"
                        asset info:mdl:sourceAsset = @deps/mdl/OmniPBR.mdl@
                        token info:mdl:sourceAsset:subIdentifier = "OmniPBR"
                        color3f inputs:diffuse_color_constant = (1, 0.48, 0.04)
                        float inputs:reflection_roughness_constant = 0.45
                        token outputs:out
                    }
                }
