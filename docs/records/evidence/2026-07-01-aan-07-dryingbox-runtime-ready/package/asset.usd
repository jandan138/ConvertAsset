        def Xform "obj_obj_conical_bottle02" (
            prepend payload = @deps/usd/scene.usd@</World/conical_bottle02>
        )
        {
            double3 xformOp:translate = (0.28, 0, 0.8)
            over "mesh"
            {
                color3f[] primvars:displayColor = [(0.1, 0.48, 0.95)]
                uniform token primvars:displayColor:interpolation = "constant"
            }
        }
        def Xform "obj_obj_beaker2" (
