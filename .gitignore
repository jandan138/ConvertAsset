*.pyc
*.pyd
*.pyo

# Build artifacts (if any in future)
dist/
build/
.trae/

# Output files
*.glb

# Paper LaTeX build artifacts
paper/writing/*.aux
paper/writing/*.bbl
paper/writing/*.blg
paper/writing/*.log
paper/writing/*.out

# ML model weights (downloaded at runtime)
*.pt
*.pth
*.onnx

